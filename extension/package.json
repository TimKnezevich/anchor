{
  "name": "axis-vscode-extension",
  "displayName": "Axis",
  "description": "Deterministic intent engine workflow for AI-driven development",
  "version": "0.0.1",
  "publisher": "axis",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://example.com/axis.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon-128.png",
  "activationEvents": [
    "onCommand:axis.initializeRepository",
    "onCommand:axis.openGraphExplorer",
    "onCommand:axis.checkConnection"
  ],
  "main": "./src/vscode-extension.js",
  "type": "module",
  "files": [
    "src/**",
    "media/**",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "axisSidebar",
          "title": "Axis",
          "icon": "media/icon-32.png"
        }
      ]
    },
    "views": {
      "axisSidebar": [
        {
          "id": "axisControl",
          "name": "Workspace"
        }
      ]
    },
    "commands": [
      {
        "command": "axis.initializeRepository",
        "title": "Axis: Initialize Repository"
      },
      {
        "command": "axis.checkConnection",
        "title": "Axis: Check Connection"
      },
      {
        "command": "axis.openGraphExplorer",
        "title": "Axis: Open Graph Explorer"
      }
    ]
  },
  "scripts": {
    "package": "npx @vscode/vsce package --no-dependencies --out ../dist/axis-vscode-extension.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2"
  }
}
