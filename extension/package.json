{
  "name": "axis-vscode-extension",
  "displayName": "Axis",
  "description": "Deterministic intent engine workflow for AI-driven development",
  "version": "0.0.1",
  "publisher": "axis",
  "license": "UNLICENSED",
  "repository": {
    "type": "git",
    "url": "https://example.com/axis.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "icon": "media/icon-128.png",
  "activationEvents": [
    "onCommand:axis.startTask",
    "onCommand:axis.confirmTask",
    "onCommand:axis.showTaskState",
    "onCommand:axis.openGraphExplorer",
    "onCommand:axis.checkConnection"
  ],
  "main": "./src/vscode-extension.js",
  "type": "module",
  "files": [
    "src/**",
    "media/**",
    "README.md",
    "readme.md",
    "LICENSE",
    "package.json"
  ],
  "contributes": {
    "commands": [
      {
        "command": "axis.startTask",
        "title": "Axis: Start Task"
      },
      {
        "command": "axis.confirmTask",
        "title": "Axis: Confirm Task"
      },
      {
        "command": "axis.showTaskState",
        "title": "Axis: Show Task State"
      },
      {
        "command": "axis.openGraphExplorer",
        "title": "Axis: Open Graph Explorer"
      },
      {
        "command": "axis.checkConnection",
        "title": "Axis: Check Connection"
      }
    ]
  },
  "scripts": {
    "package": "npx @vscode/vsce package --no-dependencies --out ../dist/axis-vscode-extension.vsix"
  },
  "devDependencies": {
    "@vscode/vsce": "^3.2.2"
  }
}
